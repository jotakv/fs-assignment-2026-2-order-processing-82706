{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "SportsStoreConnection": "Server=(localdb)\\MSSQLLocalDB;Database=SportsStore;MultipleActiveResultSets=true",
    "IdentityConnection": "Server=(localdb)\\MSSQLLocalDB;Database=Identity;MultipleActiveResultSets=true"
  },
  "ClientApp": {
    "BaseUrl": "https://localhost:7049",
    "CheckoutSuccessPath": "/checkout/complete",
    "CheckoutCancelPath": "/checkout/cancel"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File",
      "Serilog.Sinks.Seq",
      "Serilog.Enrichers.Environment"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithEnvironmentName"
    ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "shared": true
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ]
  },
  "Stripe": {
    "PublishableKey": "",
    "SecretKey": ""
  },
  "RabbitMq": {
    "Uri": "",
    "HostName": "seal.lmq.cloudamqp.com",
    "Port": 5671,
    "UserName": "brugqmwu",
    "Password": "gziF90imcO6E--xEWP8QBRqWfbBxvlQM",
    "VirtualHost": "brugqmwu",
    "UseTls": true,
    "ExchangeName": "sportsstore.orders",
    "OrderSubmittedRoutingKey": "order.submitted",
    "InventoryConfirmedRoutingKey": "inventory.confirmed",
    "InventoryFailedRoutingKey": "inventory.failed",
    "InventoryQueueName": "sportsstore.inventory",
    "PaymentApprovedRoutingKey": "payment.approved",
    "PaymentRejectedRoutingKey": "payment.rejected",
    "PaymentQueueName": "sportsstore.payment",
    "ShippingCreatedRoutingKey": "shipping.created",
    "ShippingFailedRoutingKey": "shipping.failed",
    "ShippingQueueName": "sportsstore.shipping"
  }
}
