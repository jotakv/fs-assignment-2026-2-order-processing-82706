@inherits LayoutComponentBase
@implements IDisposable
@inject CartState CartState

<div class="shell">
    <aside class="sidebar">
        <NavMenu />
    </aside>

    <main class="main-panel">
        <header class="topbar">
            <div>
                <p class="eyebrow">Blazor + API storefront</p>
                <a class="brand-link" href="">SportsStore</a>
            </div>

            <NavLink class="cart-chip" href="cart">
                <span>@CartState.ItemCount item(s)</span>
                <strong>@CartState.TotalAmount.ToString("C")</strong>
            </NavLink>
        </header>

        <article class="content">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

@code {
    protected override void OnInitialized()
    {
        CartState.Changed += OnCartChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CartState.InitializeAsync();
            StateHasChanged();
        }
    }

    private void OnCartChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        CartState.Changed -= OnCartChanged;
    }
}
