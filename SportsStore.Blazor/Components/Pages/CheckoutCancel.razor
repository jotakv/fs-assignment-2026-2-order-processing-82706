@page "/checkout/cancel"

<PageTitle>Checkout Cancelled</PageTitle>

<section class="page-card status-card">
    <h1>Checkout cancelled</h1>
    <p>The payment session was cancelled. Your cart is still in the browser session, so you can try again.</p>
    <div class="status-actions">
        <NavLink class="secondary-button" href="/cart">Back to cart</NavLink>
        <NavLink class="action-button" href="/checkout">Try checkout again</NavLink>
    </div>
</section>
